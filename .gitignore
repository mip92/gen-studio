node_modules
# Keep environment variables out of version control
.env

/generated/prisma

# Build output
dist

# Local data — exclude heavy subdirs (datasets, generated shots, reference assets)
# but keep ComfyUI workflow templates which are tiny JSON and shared across the team.
data/*/character_pipeline/
data/*/characters/
data/*/datasets/
data/*/reference/
data/*/shots/
# Generated TTS narration audio (large wavs, regenerated on demand).
data/*/scenes/

# Manual backups of comfy templates
data/*/comfy/*.bak

# Locally-downloaded Silero TTS model checkpoint (~140MB, user drops manually
# per scripts/tts_silero.py instructions; way over GitHub's per-file limit).
.silero_cache/
