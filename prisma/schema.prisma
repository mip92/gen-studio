generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Project ─────────────────────────────────────────────────────────────────

model Project {
  id        String   @id @default(uuid())
  slug      String   @unique
  name      String
  settings  Json?
  /// Full narration script for the project (Markdown). Source of truth lives
  /// in the database so the API can serve it without depending on filesystem
  /// state. Scenes hold their own snippet of this in Scene.narrationText.
  scriptText String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  characters        Character[]
  scenes            Scene[]
  shots             Shot[]
  workflowTemplates WorkflowTemplate[]
  workflowRoutes    WorkflowRoute[]
  referenceAssets   ReferenceAsset[]

  @@map("projects")
}

// ─── Characters ──────────────────────────────────────────────────────────────

model Character {
  id          String   @id @default(uuid())
  projectId   String
  code        String
  displayName String?
  createdAt   DateTime @default(now())

  project          Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  profiles         CharacterProfile[]
  shotParticipants ShotParticipant[]

  @@unique([projectId, code])
  @@map("characters")
}

model CharacterProfile {
  id             String   @id @default(uuid())
  characterId    String
  profileCode    String
  ageLabel       String?
  targetImages   Int?
  promptBase     String
  negative       String?
  promptAngles   String?
  promptVariety  String?
  datasetPath    String?
  /// "Active" LoRA — the one used by default for scene rendering. Defaults to
  /// the final epoch from the most recent successful training; user can switch
  /// to any entry in `loraVariants` via the UI to test intermediate checkpoints.
  loraPath       String?
  /// All trained LoRA files for this profile (final + epoch checkpoints from
  /// every successful training run). Each entry is { filename, fullPath, epoch?, sizeBytes, mtime, label }.
  /// Latest training overwrites this list to reflect current disk state.
  loraVariants   Json?
  triggerToken   String?
  createdAt      DateTime @default(now())

  character        Character         @relation(fields: [characterId], references: [id], onDelete: Cascade)
  datasetJobs      DatasetJob[]
  trainingJobs     TrainingJob[]
  shotParticipants ShotParticipant[]

  @@unique([characterId, profileCode])
  @@map("character_profiles")
}

// ─── Reference Assets ────────────────────────────────────────────────────────

model ReferenceAsset {
  id          String   @id @default(uuid())
  projectId   String
  profileCode String
  path        String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, profileCode])
  @@map("reference_assets")
}

// ─── Scenes ──────────────────────────────────────────────────────────────────

model Scene {
  id                          String   @id @default(uuid())
  projectId                   String
  sceneKey                    String
  title                       String?
  sortOrder                   Int      @default(0)
  defaultReferenceProfileCode String?
  /// Closed-caption / voiceover text for the scene. Plain Russian narrator
  /// script — Silero V5 ru synthesises this to data/<slug>/scenes/<sceneKey>/narration.wav.
  /// Edits don't retroactively change rendered TTSJob outputs — each job
  /// snapshots `text` at enqueue time.
  narrationText               String?
  /// Reference to the project narration script: which lines in
  /// <slug>_script.md this scene covers (inclusive). Lets the UI link back
  /// "scene → source paragraphs" without duplicating ranges in code.
  scriptStartLine             Int?
  scriptEndLine               Int?
  createdAt                   DateTime @default(now())

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  shots     Shot[]
  ttsJobs   TTSJob[]

  @@unique([projectId, sceneKey])
  @@map("scenes")
}

// ─── Shots ───────────────────────────────────────────────────────────────────

model Shot {
  id                 String   @id @default(uuid())
  projectId          String
  sceneId            String
  shotCode           String
  promptFields       Json?
  workflowRouteKey   String?
  referenceProfileId String?
  referenceImagePool Json?
  /// Accumulated rendered candidates for this shot.
  /// Shape: [{filename, promptId, seed, strategyId, createdAt}]
  renderedImages     Json?
  /// Filename of the candidate chosen as the canonical render for this shot.
  chosenRender       String?
  /// VideoRender.id chosen as the final/approved animation for this shot.
  /// Mirrors `chosenRender` for videos: once set, the scenes UI offers an upscale
  /// instead of another render, and downstream packaging treats this as the
  /// canonical motion clip. No FK so the row stays self-consistent if the video
  /// is hard-deleted; the setChosenVideo service validates membership.
  chosenVideoId      String?
  /// Latest in-flight ComfyUI prompt_id for this shot (cleared once result is recorded).
  activeRenderPromptId String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  project      Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scene        Scene             @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  participants ShotParticipant[]
  renderJobs   SceneRenderJob[]
  videoRenders VideoRender[]

  @@unique([projectId, shotCode])
  @@index([projectId, sceneId])
  @@map("shots")
}

model ShotParticipant {
  id          String  @id @default(uuid())
  shotId      String
  characterId String?
  /// Which character profile (LoRA + age variant) to use for this participant
  /// in this specific shot. Null = renderer falls back to the first profile
  /// of the character that has a trained LoRA.
  profileId   String?
  label       String

  shot      Shot              @relation(fields: [shotId], references: [id], onDelete: Cascade)
  character Character?        @relation(fields: [characterId], references: [id], onDelete: SetNull)
  profile   CharacterProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)

  @@map("shot_participants")
}

// ─── Workflow ─────────────────────────────────────────────────────────────────

model WorkflowTemplate {
  id          String   @id @default(uuid())
  projectId   String
  templateKey String
  filePath    String
  description String?
  createdAt   DateTime @default(now())

  project    Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  routeSteps WorkflowRouteStep[]

  @@unique([projectId, templateKey])
  @@map("workflow_templates")
}

model WorkflowRoute {
  id        String   @id @default(uuid())
  projectId String
  routeKey  String
  createdAt DateTime @default(now())

  project Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  steps   WorkflowRouteStep[]

  @@unique([projectId, routeKey])
  @@map("workflow_routes")
}

model WorkflowRouteStep {
  id                 String @id @default(uuid())
  workflowRouteId    String
  stepOrder          Int
  workflowTemplateId String

  workflowRoute    WorkflowRoute    @relation(fields: [workflowRouteId], references: [id], onDelete: Cascade)
  workflowTemplate WorkflowTemplate @relation(fields: [workflowTemplateId], references: [id], onDelete: Restrict)

  @@unique([workflowRouteId, stepOrder])
  @@map("workflow_route_steps")
}

// ─── Training ─────────────────────────────────────────────────────────────────

model DatasetJob {
  id                  String    @id @default(uuid())
  profileId           String
  status              String    // pending | blocked | running | completed | failed | cancelled
  /// If set, this job waits until the named profile's dataset has at least one image.
  dependsOnProfileId  String?
  /// If set, the reference image used by ComfyUI is picked from this profile's
  /// dataset folder (chaining: HERO_TEEN_15 → HERO_OVERLOAD_16/17).
  referenceProfileId  String?
  /// Specific filename inside referenceProfileId's COMFY_OUTPUT to use as the
  /// reference. If not set, a deterministic middle image is auto-picked.
  referenceImageFilename String?
  comfyPromptId       String?
  errorMessage        String?
  queuedAt            DateTime  @default(now())
  startedAt           DateTime?
  completedAt         DateTime?

  profile CharacterProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, status])
  @@index([status])
  @@map("dataset_jobs")
}

model SceneRenderJob {
  id            String    @id @default(uuid())
  shotId        String
  status        String    // pending | running | completed | failed | cancelled
  /// ComfyUI prompt_id once dispatched; used to poll history for outputs.
  comfyPromptId String?
  /// Render parameters at enqueue time (seed, batchSize, scenePrompt override, …).
  /// Stored so the queue worker can rebuild the call after a backend restart.
  params        Json?
  errorMessage  String?
  queuedAt      DateTime  @default(now())
  startedAt     DateTime?
  completedAt   DateTime?

  shot Shot @relation(fields: [shotId], references: [id], onDelete: Cascade)

  @@index([shotId])
  @@index([status, queuedAt])
  @@map("scene_render_jobs")
}

// ─── Video renders ───────────────────────────────────────────────────────────
//
// Image-to-video renders driven by Wan2.2 i2v. One row per submitted job; the
// row holds the source image (the shot's approved render), the motion prompt,
// and the resulting mp4 filename once ComfyUI finishes.

model VideoRender {
  id                  String    @id @default(uuid())
  shotId              String
  /// Which image was used as the i2v starting frame. Stored as the basename
  /// inside `data/<project>/shots/<shotCode>/`.
  sourceImageFilename String
  /// Motion prompt — what should the animated frame do (camera move, subject
  /// movement, etc.). Concatenated into the Wan2.2 positive prompt.
  motionPrompt        String
  /// Lifecycle: pending → running → completed | failed | cancelled.
  status              String
  /// ComfyUI prompt_id once dispatched; used to poll history.
  comfyPromptId       String?
  /// Render parameters at enqueue time (seed, length, fps, width, height, etc.)
  params              Json?
  /// Basename of the output mp4 in `data/<project>/shots/<shotCode>/videos/`.
  outputFilename      String?
  /// Workflow filename used (e.g. "video_wan22_i2v_api.json").
  workflowFilename    String
  errorMessage        String?
  queuedAt            DateTime  @default(now())
  startedAt           DateTime?
  completedAt         DateTime?

  /// Upscale-on-demand (4x-UltraSharp → 1920×1080). Null until user clicks
  /// "upscale" on a completed video. Lifecycle mirrors the main status field.
  upscaleStatus        String?
  upscaledFilename     String?
  upscalePromptId      String?
  /// When this row's upscale lifecycle entered `pending`. Distinct from the
  /// main render's `queuedAt` because an upscale is requested some time after
  /// the underlying video finishes — sorting upscales by `queuedAt` would
  /// place every new upscale ahead of newly-queued renders.
  upscaleQueuedAt      DateTime?
  upscaleStartedAt     DateTime?
  upscaleCompletedAt   DateTime?
  upscaleErrorMessage  String?

  shot Shot @relation(fields: [shotId], references: [id], onDelete: Cascade)

  @@index([shotId])
  @@index([status, queuedAt])
  @@index([upscaleStatus, upscaleQueuedAt])
  @@map("video_renders")
}

model TrainingJob {
  id             String    @id @default(uuid())
  profileId      String
  status         String    // pending | preparing | captioning | training | completed | failed
  baseModel      String
  triggerToken   String?
  datasetPath    String?
  configPath     String?
  outputLoraPath String?
  logPath        String?
  errorMessage   String?
  progress       Json?     // { phase, current, total, ... }
  /// Effective queue ordering timestamp. Mirrors DatasetJob.queuedAt so the
  /// pipeline queue can order both job types by one field. Defaults to now()
  /// at row creation; gets swapped when the user reorders the queue in UI.
  queuedAt       DateTime  @default(now())
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  profile CharacterProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, status])
  @@index([status, queuedAt])
  @@map("training_jobs")
}

// ─── TTS (Silero V5 ru) ──────────────────────────────────────────────────────
//
// One row per "synthesise this scene's narration" request. Runs on CPU via a
// Python subprocess (scripts/tts_silero.py) and is independent of ComfyUI /
// GPU jobs, so the pipeline tick dispatches it in parallel with everything
// else (still one TTS at a time though).

model TTSJob {
  id             String    @id @default(uuid())
  sceneId        String
  /// Text snapshot at enqueue time. Editing Scene.narrationText later does NOT
  /// retroactively change rendered audio — re-queue to regenerate.
  text           String
  /// Silero V5 ru speaker id: aidar | baya | kseniya | xenia | eugene | random.
  voice          String
  /// Output sample rate: 8000 | 24000 | 48000 (Silero supports these three).
  sampleRate     Int
  /// Playback rate (1.0 = normal, <1 slower, >1 faster). Implemented via SSML
  /// `<prosody rate="X%">…</prosody>` wrapping in the Python worker.
  rate           Float     @default(1.0)
  status         String    // pending | running | completed | failed | cancelled
  /// Basename of the wav inside data/<slug>/scenes/<sceneKey>/.
  outputFilename String?
  errorMessage   String?
  queuedAt       DateTime  @default(now())
  startedAt      DateTime?
  completedAt    DateTime?

  scene Scene @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  @@index([sceneId])
  @@index([status, queuedAt])
  @@map("tts_jobs")
}
